algoritmo "semnome"
var
   N1, N2, N3, N4, N5, N6, N7, S:inteiro
inicio
      Escreval("Digite o 1 n·mero: ")
      Leia(N1)
      Escreval("Digite o 2 n·mero: ")
      Leia(N2)
      Escreval("Digite o 3 n·mero: ")
      Leia(N3)
      Escreval("Digite o 4 n·mero: ")
      Leia(N4)
      Escreval("Digite o 5 n·mero: ")
      Leia(N5)
      Escreval("Digite o 6 n·mero: ")
      Leia(N6)
      S <- N1 +N2 + N3 + N4 + N5 + N6
      Escreval(" A soma desses n·meros ķ igua a ",S)
fimalgoritmo
