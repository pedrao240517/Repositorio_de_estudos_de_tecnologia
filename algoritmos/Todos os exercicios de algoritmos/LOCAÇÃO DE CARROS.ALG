algoritmo "Locação de carros"
var
     KM,D,P:real
inicio
       Escreva("Quantos Km seu carro percorreu? ")
       Leia(KM)
       Escreva("Por quantos dias ele percorreu? ")
       Leia(D)
       P<- (KM*0.20)+(D*90)
       Escreva(" O preço total pra compra do carro é igua a ",P)
       
fimalgoritmo