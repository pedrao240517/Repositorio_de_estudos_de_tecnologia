algoritmo "aumento de sálario"
var
       N1:caractere
       S,P,A:real
inicio
        Escreva("Qual é seu nome? ")
        Leia(N1)
        Escreval("Muito prazer, ", N1)
        Escreva("Quanto vocę recebe de salário? ")
        Leia(S)
        P<- S*15/100
        A<-S+P
        Escreva(" Seu sálario aumento para: ", A, " Reais")

fimalgoritmo