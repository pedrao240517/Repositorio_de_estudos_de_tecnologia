algoritmo "Exibidor de  sálario"
var
       N1:caractere
       S:real
inicio
        Escreva("Qual é seu nome? ")
        Leia(N1)
        Escreval("Muito prazer, ", N1)
        Escreva("Quanto vocę recebe de salário? ")
        Leia(S)
        Escreva(" A funcionária/o ", N1," recebe de salário:",S,"reais")
        
fimalgoritmo